{
  "manifest_version": 3,
  "name": "Content Censor & YouTube Hider",
  "version": "1.0",
  "description": "Censors adult content and hides YouTube recommendations",
  "permissions": ["activeTab", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "trigger-khan-primary-action": {
      "description": "Trigger the Khan Academy primary action"
    }
  },
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://www.khanacademy.org/*",
    "https://khanacademy.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-trace.js"],
      "matches": ["https://www.khanacademy.org/*", "https://khanacademy.org/*"]
    }
  ]
}
