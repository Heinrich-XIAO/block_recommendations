{
  "manifest_version": 3,
  "name": "Content Censor & YouTube Hider",
  "version": "1.0",
  "description": "Censors adult content and hides YouTube recommendations",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://openrouter.ai/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
